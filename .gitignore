# --- [Lo] SECURITY: The Identity Shredder Guard ----------------------
# Prevent sensitive keys and temporary data from reaching GitHub.

# CRITICAL: Prevent leaking Supabase and LLM API keys
.env
.env.local
.env.*.local
!.env.example

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Node.js
node_modules/
.next/
out/

# Logs and Debugging
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS Specific
.DS_Store
Thumbs.db

# Agent Zero / AI Temporary Workspaces
tmp/
workspace/temp/
.agents/logs/

# IDE Specific
.vscode/
.idea/
*.swp
*.swo

# Test artifacts
test_app.py

# Project Data (Optional: Ignore if using large local backups)
data/v1_backup.sql
