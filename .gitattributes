# =============================================================================
# .gitattributes — Line Ending Normalization
# Project: WINC Incubator Vault
# Purpose: Prevents the "hundreds of modified files" noise caused by
#          Windows CRLF vs Linux LF differences when developing across
#          both Windows (local) and Linux (Docker/CI) environments.
# =============================================================================

# Default: normalize all text files to LF on commit
* text=auto

# Explicitly LF for all code and config files
*.py      text eol=lf
*.sh      text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.toml    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.json    text eol=lf
*.sql     text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.js      text eol=lf
*.ts      text eol=lf
*.ini     text eol=lf
*.cfg     text eol=lf
*.env     text eol=lf

# Binary files — never normalize
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.svg     binary
*.pdf     binary
*.ttf     binary
*.woff    binary
*.woff2   binary
*.zip     binary
*.gz      binary
*.pyc     binary
